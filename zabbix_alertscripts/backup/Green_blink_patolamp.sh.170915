#!/bin/sh
#------------------------------------------------------------------------------
# drive BAO-GW system patlamp in Shinjuku-OC by zabbix server
# usage: Green_blink_patolamp.sh <no parameters>
# response: 0(always normal)
#------------------------------------------------------------------------------

#---- define constants ----
PATOLAMP_FILE=/var/lib/baogw/green_patolamp_on

#---- define variables ----
PGNAME=`basename $0 .sh`
#PROCESS_ID=$$

#---- define functions ----
function putlog_w() {
  logger -i -p local6.warn "WARN: ${PGNAME} ($1) ${LOGMSG}"
}

function putlog_i() {
  logger -i -p local6.info "INFO: ${PGNAME} ($1) ${LOGMSG}"
}

#---- start ----
putlog_i "started."

#---- execute make file ----
# do
  touch ${PATOLAMP_FILE}
#---- end ----
putlog_i "ended"
exit 0

#EOF


